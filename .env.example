# ─── Chaves de API ──────────────────────────────────────
# O sistema só exibe APIs com chave configurada.
# Nenhuma exige cartão de crédito.

# Google Gemini (2.5 Flash para geração, 2.5 Pro para judge)
GEMINI_API_KEY=

# Groq (Llama 3.3 70B — formato OpenAI)
GROQ_API_KEY=

# DeepSeek (V3.2 — formato OpenAI)
DEEPSEEK_API_KEY=

# ─── Configuração ──────────────────────────────────────
LOG_LEVEL=INFO
FLASK_SECRET_KEY=change-me-in-production
