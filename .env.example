# ─── Chaves de API ──────────────────────────────────────
# O sistema só exibe modelos com chave configurada.

# Google Gemini (2.5 Flash para geração, 2.5 Pro para judge)
GEMINI_API_KEY=

# Groq (Llama 4 Scout, GPT-OSS 120B, DeepSeek R1 70B, Qwen 3 32B)
GROQ_API_KEY=

# OpenRouter (GPT-4.1 Mini, Grok 4.1 Fast, DeepSeek V3.2, Mistral Small 3.1)
OPENROUTER_API_KEY=

# ─── Configuração ──────────────────────────────────────
LOG_LEVEL=INFO
FLASK_SECRET_KEY=change-me-in-production
